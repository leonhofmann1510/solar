# Frontend environment variables
# Copy this file to .env for local development

# Backend API base URL (include protocol + host, no trailing slash)
# Local dev: point directly at the backend
# Docker:    leave empty — nginx proxies /api/ and /ws to the backend container
VITE_API_BASE_URL=http://localhost:8000

# WebSocket base URL (ws:// or wss://)
# Local dev: point directly at the backend
# Docker:    leave empty — URL is derived from window.location automatically
VITE_WS_BASE_URL=ws://localhost:8000
