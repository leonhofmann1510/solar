# Database (local dev against Docker Postgres)
DB_HOST=localhost
DB_PORT=5433
DB_USER=solarflow
DB_PASSWORD=changeme
DB_NAME=solarflow

# Modbus
# inv1 is the hybrid inverter (battery-connected)
MODBUS_IP_INVERTER_1=192.168.178.24
# inv2 is the string-only inverter (no battery)
MODBUS_IP_INVERTER_2=192.168.178.26
MODBUS_PORT=502
MODBUS_UNIT_ID=1
POLL_INTERVAL_SECONDS=30

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Rules
RULES_FILE_PATH=../rules/example_rules.yaml

# Tuya Cloud (for device discovery and local key fetch)
# 1. Go to https://iot.tuya.com/
# 2. Create a Cloud Project
# 3. Get API Key and Secret from Cloud -> Development
# 4. Set static DHCP reservations for your Tuya devices before fetching keys
TUYA_API_KEY=your_api_key_here
TUYA_API_SECRET=your_api_secret_here
TUYA_API_REGION=eu

# Device Discovery
# Zigbee2MQTT bridge topic that publishes full device list
ZIGBEE2MQTT_BRIDGE_TOPIC=zigbee2mqtt/bridge/devices
# Timeout for mDNS device scanning
MDNS_SCAN_TIMEOUT_SECONDS=10
